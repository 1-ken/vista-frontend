# Frontend environment variables for Vite
# Prefix with VITE_ to expose to client-side code

# Local dev server port (npm run dev) — change if 5173 is already in use
PORT=5173

# Production build preview port (npm run preview)
PREVIEW_PORT=4173

# Backend API base URL
# Local dev: use /api (proxied to backend via vite.config.js)
# Vercel production: set VITE_API_URL=/api in Project Settings → Environment Variables
VITE_API_URL=/api

# Socket server URL (same host/port as backend by default)
VITE_SOCKET_URL=http://localhost:5000

# Asset base URL used to load uploaded images (no trailing slash)
VITE_ASSET_BASE_URL=http://localhost:5000

# Vercel deployment checklist:
# 1. Set VITE_API_URL=/api for Production (and Preview if needed)
# 2. vercel.json proxies /api/* → https://fxalerts.applawn.com/api/*
# 3. Redeploy after changing env vars (Vite bakes VITE_* at build time)
